{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "keytao-installer",
  "version": "999.0.0",
  "identifier": "ink.rea.keytao-installer",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "键道安装器",
        "width": 800,
        "height": 700
      },
      {
        "label": "ime-overlay",
        "title": "KeyTao IME",
        "width": 600,
        "height": 220,
        "alwaysOnTop": true,
        "transparent": true,
        "decorations": false,
        "visible": false,
        "resizable": false,
        "skipTaskbar": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "dmg",
      "nsis",
      "deb",
      "appimage"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}